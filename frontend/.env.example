# MediBridge AI – Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will NOT be committed.

# Backend API base URL
# In development the Vite proxy rewrites /api → http://localhost:8000
# Set this to your production API URL when deploying.
VITE_API_BASE_URL=/api

# App environment ('development' | 'production')
VITE_ENV=development
