# MediBridge AI - Environment Configurations

# FastAPI configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True
ENVIRONMENT=development

# Neon PostgreSQL Database URL
# Example: postgresql://username:password@ep-cool-name.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-something.us-east-1.aws.neon.tech/medibridge?sslmode=require

# Mistral AI configuration
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-medium

# Security
SECRET_KEY=generate_a_secure_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
